# Copy this file to .env and fill in your own values.
# Do not commit .env.

# Optional notification channels: email, serverchan, wxpusher
RESEARCH_NOTIFY_CHANNELS=

# Optional email settings
RESEARCH_SMTP_HOST=
RESEARCH_SMTP_PORT=465
RESEARCH_SMTP_USERNAME=
RESEARCH_SMTP_PASSWORD=
RESEARCH_SMTP_FROM=
RESEARCH_EMAIL_TO=

# Optional ServerChan Turbo send key
RESEARCH_SERVERCHAN_SENDKEY=

# Optional WxPusher settings
RESEARCH_WXPUSHER_SPT=
RESEARCH_WXPUSHER_APP_TOKEN=
RESEARCH_WXPUSHER_UIDS=

# Optional market data provider tokens
RESEARCH_TUSHARE_TOKEN=
